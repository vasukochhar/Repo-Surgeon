# Copy this file to .env, then replace blank values with your own credentials.
# The application defaults to mock mode, which does not call external services.
REPO_SURGEON_MODE=mock

# Required only when REPO_SURGEON_MODE=real.
OPENAI_API_KEY=
GITHUB_TOKEN=

# Repo Surgeon deliberately permits only this model for active OpenAI calls.
REPO_SURGEON_MODEL=gpt-5.6-luna
REPO_SURGEON_RESEARCH_MODEL=gpt-5.6-luna

# Registry-first dependency research. Batches are clamped to 1-5 packages.
REPO_SURGEON_RESEARCH_BATCH_SIZE=1
REPO_SURGEON_MAX_CONCURRENT_RESEARCH=1
REPO_SURGEON_RESEARCH_MAX_ATTEMPTS=5
REPO_SURGEON_RESEARCH_RETRY_MIN_SECONDS=5
REPO_SURGEON_RESEARCH_RETRY_MAX_SECONDS=90
REPO_SURGEON_RESEARCH_RETRY_JITTER=0.25
REPO_SURGEON_RESEARCH_TIMEOUT=240
REPO_SURGEON_RESEARCH_CACHE=.repo-surgeon-cache/research.json
REPO_SURGEON_SECURITY_CACHE_TTL=86400
REPO_SURGEON_RESEARCH_CACHE_TTL=2592000

# Enforced context budgets. Counts are estimated deterministically when an
# optional tokenizer is not installed.
REPO_SURGEON_PLANNER_RESEARCH_TARGET_TOKENS=8000
REPO_SURGEON_PLANNER_RESEARCH_MAX_TOKENS=20000
REPO_SURGEON_RESEARCH_CARD_TOKENS=600
REPO_SURGEON_SURGEON_CONTEXT_TOKENS=1500
REPO_SURGEON_RESEARCH_SOURCE_CHARS=8000
REPO_SURGEON_RESEARCH_MAX_SOURCES=5

# Optional second-pass summarization is off by default and used only when
# deterministic cleanup cannot fit an oversized card.
REPO_SURGEON_ENABLE_SUMMARIZATION=false
REPO_SURGEON_SUMMARIZER_MODEL=gpt-5.6-luna

# Verification policy: coverage "final", "always", or "disabled"; mutation "relevant"
# or "disabled". Relevant mutation requires both tests and source changes.
REPO_SURGEON_COVERAGE_POLICY=final
REPO_SURGEON_MUTATION_POLICY=relevant
