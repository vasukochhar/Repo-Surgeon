# Copy this file to .env, then replace blank values with your own credentials.
# The application defaults to mock mode, which does not call external services.
REPO_SURGEON_MODE=mock

# Required only when REPO_SURGEON_MODE=real.
OPENAI_API_KEY=
GITHUB_TOKEN=

# Optional. Planner uses the flagship reasoning tier; Researcher uses the cheap
# fast tier with web search. These are the defaults.
REPO_SURGEON_MODEL=gpt-5.6-sol
REPO_SURGEON_RESEARCH_MODEL=gpt-5.6-luna
